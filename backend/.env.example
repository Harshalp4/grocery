# Copy to `.env` and fill in. NEVER commit the real .env.

# PostgreSQL connection. Standard local Postgres is port 5432.
# (This project's original dev machine ran Postgres on 5433 — adjust to yours.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/farmfresh?schema=public"

PORT=4000

# Admin panel login (change these!)
ADMIN_EMAIL="admin@farmfresh.local"
ADMIN_PASSWORD="farmfresh123"

# Long random string. Signs both admin and customer JWTs.
JWT_SECRET="change-me-to-a-long-random-string"

# Dev returns the OTP in the API response so login works without SMS.
# Set to "false" and wire a real SMS provider (src/customerAuth.ts) for prod.
OTP_DEV_MODE="true"

# Optional — real online payments (not implemented yet; COD works without these)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
